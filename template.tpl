___TESTS___

scenarios:
- name: Tag fires successfully with project ID
  code: |-
    const mockData = {
      projectId: 'test-project-123'
    };

    runCode(mockData);

    assertApi('setInWindow').wasCalledWith('promptwatchConfig', {
      projectId: 'test-project-123'
    }, false);

    assertApi('injectScript').wasCalled();
- name: Does not overwrite existing config
  code: |-
    mock('copyFromWindow', function(key) {
      if (key === 'promptwatchConfig') {
        return { projectId: 'existing-project' };
      }
      return undefined;
    });

    const mockData = {
      projectId: 'new-project-123'
    };

    runCode(mockData);

    assertApi('setInWindow').wasNotCalled();
    assertApi('injectScript').wasCalled();
setup: ''


